{
  "crons": [
    {
      "path": "/api/admin/consolidate-memory",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/admin/stripe-audit",
      "schedule": "0 3 * * *"
    }
  ],
  "functions": {
    "src/app/api/**/*": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
